// Prisma Schema for Personal Website
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// 用户表（后台管理员）
model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String   // 加密存储
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

// 博客文章表
model BlogPost {
  id        Int      @id @default(autoincrement())
  title     String
  slug      String   @unique  // URL友好标识
  content   String   // Markdown内容
  excerpt   String?  // 摘要
  coverImage String?  // 封面图
  tags      String?  // 标签（逗号分隔）
  published Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("blog_posts")
}

// 项目表
model Project {
  id          Int      @id @default(autoincrement())
  name        String
  slug        String   @unique
  description String
  techStack   String?  // 技术栈（逗号分隔）
  screenshots String?  // 截图路径（逗号分隔）
  githubUrl   String?
  demoUrl     String?
  featured    Boolean  @default(false) // 是否精选
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("projects")
}

// 生活记录表
model LifePost {
  id        Int      @id @default(autoincrement())
  content   String   // 文字描述
  images   String?  // 图片路径（逗号分隔）
  createdAt DateTime @default(now())

  @@map("life_posts")
}
